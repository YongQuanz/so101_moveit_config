<?xml version="1.0"?>
<robot xmlns:xacro="http://www.ros.org/wiki/xacro">
    <xacro:macro name="so101_ros2_control_real" params="name">
        <ros2_control name="${name}" type="system">
            <hardware>
                <plugin>so101_hardware_interface/So101HardwareInterface</plugin>
                <!-- USB serial port exposed by the Waveshare Bus Servo Adapter -->
                <param name="device_port">/dev/ttyACM0</param>
                <!-- ST-series default baud rate: 1 000 000 -->
                <param name="baud_rate">1000000</param>
                <!-- Comm timeout in seconds -->
                <param name="timeout">1.0</param>
                <!-- Speed in raw steps/s (0 = max servo speed, ~2400 typical) -->
                <param name="default_speed">0</param>
                <!-- Acceleration 0–254 (0 = no limit) -->
                <param name="default_acc">50</param>
            </hardware>

            <!-- Joint 1 → base→shoulder (shoulder pan) -->
            <joint name="shoulder_pan">
                <param name="servo_id">1</param>
                <command_interface name="position"/>
                <state_interface name="position"/>
                <state_interface name="velocity"/>
            </joint>

            <!-- Joint 2 → shoulder→upper_arm (shoulder lift) -->
            <joint name="shoulder_lift">
                <param name="servo_id">2</param>
                <command_interface name="position"/>
                <state_interface name="position"/>
                <state_interface name="velocity"/>
            </joint>

            <!-- Joint 3 → upper_arm→lower_arm (elbow flex) -->
            <joint name="elbow_flex">
                <param name="servo_id">3</param>
                <command_interface name="position"/>
                <state_interface name="position"/>
                <state_interface name="velocity"/>
            </joint>

            <!-- Joint 4 → lower_arm→wrist (wrist flex) -->
            <joint name="wrist_flex">
                <param name="servo_id">4</param>
                <command_interface name="position"/>
                <state_interface name="position"/>
                <state_interface name="velocity"/>
            </joint>

            <!-- Joint 5 → wrist→gripper (wrist roll) -->
            <joint name="wrist_roll">
                <param name="servo_id">5</param>
                <command_interface name="position"/>
                <state_interface name="position"/>
                <state_interface name="velocity"/>
            </joint>

            <!-- Joint 6 → gripper→moving_jaw (gripper) -->
            <joint name="gripper">
                <param name="servo_id">6</param>
                <command_interface name="position"/>
                <state_interface name="position"/>
                <state_interface name="velocity"/>
            </joint>
        </ros2_control>
    </xacro:macro>
</robot>

